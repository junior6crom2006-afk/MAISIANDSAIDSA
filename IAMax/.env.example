# Configuración de DarkMax Bot
# Copia este archivo a .env y configura tus valores

# Token del bot de Telegram (obtenido via @BotFather)
TELEGRAM_BOT_TOKEN=tu_token_aqui

# API keys de OpenRouter separadas por comas
OPENROUTER_KEYS=key1,key2,key3

# Clave de administrador (opcional, se genera automáticamente si no se define)
ADMIN_KEY=tu_admin_key_aqui

# Clave para encriptar keys.json (opcional, se genera automáticamente)
ENCRYPTION_KEY=tu_clave_de_32_caracteres